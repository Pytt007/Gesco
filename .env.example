# Variables d'environnement GESCO — Production (Supabase)
# Copiez ce fichier en .env.local et remplissez les valeurs.
# Ne commitez jamais .env.local dans git !

# ──────────────────────────────────────────────────────────────────────────
# SUPABASE — Obtenez ces valeurs sur https://supabase.com
# Projet > Settings > API
# ──────────────────────────────────────────────────────────────────────────
VITE_SUPABASE_URL=https://VOTRE_PROJET.supabase.co
VITE_SUPABASE_ANON_KEY=votre_anon_key_ici

# ──────────────────────────────────────────────────────────────────────────
# GEMINI AI (optionnel — pour les fonctionnalités IA)
# ──────────────────────────────────────────────────────────────────────────
VITE_GEMINI_API_KEY=
GEMINI_API_KEY=
